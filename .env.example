# ComponentHub MCP configuration
# Copy to .env and fill in the credentials for the providers you want to enable.
# Providers without credentials are skipped at search time and reported in
# `providers_skipped` with a hint — nothing breaks if a value is left empty.

# ── Web app (Next.js) ────────────────────────────────────────────────────────
# Public base URL of this deployment. Export/asset links are built from this.
# In production on Vercel this is inferred from VERCEL_URL if unset.
COMPONENTHUB_BASE_URL=http://127.0.0.1:3000

# Supabase (auth, saved parts, search history, projects/BOM). The app runs
# against demo data without these, but accounts/persistence need a project.
# Create one at https://supabase.com and run the migrations in supabase/migrations/.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (Project Settings → API in the Supabase dashboard). Required
# to verify per-user MCP API keys on the /api/mcp endpoint — without it, all
# MCP requests are rejected. Server-only; never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Provider filtering ───────────────────────────────────────────────────────
# Control which providers are active. By default all providers are enabled.
# Use one of these to restrict the set:
#
# ENABLED_PROVIDERS — allowlist: only these providers will be active.
#   Example: ENABLED_PROVIDERS=digikey,mouser,jlcsearch
#
# DISABLED_PROVIDERS — denylist: these providers will be excluded.
#   Example: DISABLED_PROVIDERS=demo,octopart
#
# If both are set, ENABLED_PROVIDERS takes precedence.
# ENABLED_PROVIDERS=
# DISABLED_PROVIDERS=

# ── DigiKey ── search, details, pricing, availability, datasheet ─────────────
# Create an app at https://developer.digikey.com (Product Information API v4).
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# ── Mouser ── search, details, pricing, availability, datasheet ──────────────
# Request a Search API key at https://www.mouser.com/api-hub/
MOUSER_API_KEY=

# ── Octopart (Nexar) ── search, details, pricing, availability, datasheet ────
# Octopart's official API platform. Create an app with the Supply scope at
# https://nexar.com / https://portal.nexar.com
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# ── OEMsecrets ── search, details, pricing, availability, datasheet ──────────
# Multi-distributor aggregator. Apply for a key at https://www.oemsecrets.com/api/
# Note: trial keys are capped at 10 requests/day — results are cached briefly
# in-memory to avoid burning quota on repeat lookups.
OEMSECRETS_API_KEY=
# Optional: 2-letter country code and preferred currency for pricing.
# OEMSECRETS_COUNTRY_CODE=
# OEMSECRETS_CURRENCY=USD

# ── SnapMagic (SnapEDA) ── search, cad_models, datasheet ─────────────────────
# API token from https://www.snapeda.com/api/
SNAPMAGIC_TOKEN=

# ── Ultra Librarian ── search, cad_models, datasheet ─────────────────────────
# Partner API credentials from https://developers.ultralibrarian.com
ULTRA_LIBRARIAN_CLIENT_ID=
ULTRA_LIBRARIAN_CLIENT_SECRET=
# Optional overrides if your partner account uses different endpoints:
# ULTRA_LIBRARIAN_API_BASE=https://api.ultralibrarian.com
# ULTRA_LIBRARIAN_TOKEN_URL=https://identity.ultralibrarian.com/connect/token

# ── demo ── all capabilities ─────────────────────────────────────────────────
# Built-in sample catalog, always enabled, no key needed.
